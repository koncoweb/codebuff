# KoncoVibe Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider (SumoPod AI / OpenAI-compatible)
VITE_SUMOPOD_API_KEY=sk-your-api-key-here
VITE_SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
VITE_SUMOPOD_DEFAULT_MODEL=MiniMax-M2.7-highspeed

# Neon Auth
VITE_NEON_AUTH_BASE_URL=https://your-neon-auth-url.neon.tech/neondb/auth
VITE_NEON_AUTH_PROJECT_ID=your-project-id
